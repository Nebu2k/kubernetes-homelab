apiVersion: v1
kind: Secret
metadata:
  name: training-engine-secrets
  namespace: training-engine
type: Opaque
stringData:
  db-password: "CHANGE-ME-to-a-strong-password"
  database-url: "postgresql://training_engine:CHANGE-ME-to-a-strong-password@training-engine-postgresql:5432/training_engine?schema=public"
