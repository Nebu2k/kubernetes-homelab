# .env.example file for Homelab
# Copy this to .env and customize with your values

# Your domain managed by Cloudflare
CF_DOMAIN=example.com
CF_ARGOCD_DOMAIN=argocd.example.com

# Cloudflare API credentials (get from Cloudflare dashboard)
CF_ZONE_ID=your_cloudflare_zone_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Target for DNS records (your dynamic DNS hostname or server IP)
CF_DEFAULT_TARGET=your-server.dyndns.org

# Email for Let's Encrypt certificates
CF_CERT_EMAIL=admin@example.com
